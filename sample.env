# ============================================================================
# S3/Cloudflare R2 Configuration (for MCP server resume uploads)
# ============================================================================
# S3 bucket name (one of these must be set)
# RESUME_S3_BUCKET_NAME=your-bucket-name
# RESUME_S3_BUCKET=your-bucket-name
# S3_BUCKET_NAME=your-bucket-name

# S3 endpoint URL (for Cloudflare R2 or other S3-compatible services)
# RESUME_S3_ENDPOINT_URL=https://xxxxx.r2.cloudflarestorage.com
# S3_ENDPOINT_URL=https://xxxxx.r2.cloudflarestorage.com

# AWS region or S3 region
# RESUME_S3_REGION=auto
# AWS_REGION=auto

# S3 access credentials
# RESUME_S3_ACCESS_KEY_ID=your-access-key-id
# RESUME_S3_ACCESS_KEY=your-access-key-id
# S3_ACCESS_KEY_ID=your-access-key-id
# AWS_ACCESS_KEY_ID=your-access-key-id

# RESUME_S3_SECRET_ACCESS_KEY=your-secret-access-key
# RESUME_S3_SECRET_KEY=your-secret-access-key
# S3_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

# S3 addressing style (path or virtual, auto-detected for non-AWS endpoints)
# RESUME_S3_ADDRESSING_STYLE=path

# Key prefix for uploaded resumes (default: resumes/)
# RESUME_S3_KEY_PREFIX=resumes/

# Public base URL for accessing uploaded resumes (required if using S3)
# RESUME_S3_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev

# ============================================================================
# MCP Server Configuration (Optional)
# ============================================================================
# Transport type for MCP server (stdio, sse, etc.)
# FASTMCP_TRANSPORT=stdio
# MCP_TRANSPORT=stdio
# TRANSPORT=stdio

# Port number for MCP server (if using network transport)
# FASTMCP_PORT=8000
# MCP_PORT=8000
# PORT=8000

# ============================================================================
# LaTeX Compile Service (external — see latex-compile-service/ repo)
# ============================================================================
# URL of the standalone latex-compile-service API
# LATEX_COMPILE_API_URL=https://latex-compile.k.0x1f0c.dev

# ============================================================================
# Semantic Vector Search Configuration (Optional)
# ============================================================================
# Persistent directory for ChromaDB index files
# VECTOR_DB_DIR=./data/vector_db

# Index status file path
# VECTOR_INDEX_STATUS_PATH=./data/vector_db/index_status.json

# Embedding provider for vector search: google (default) | openai
# EMBEDDING_PROVIDER=google
# Optional when using OpenRouter base URL for embeddings:
# OPENROUTER_API_KEY=your-openrouter-key
